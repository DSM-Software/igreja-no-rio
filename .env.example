# Database — Neon / Supabase / Railway PostgreSQL
DATABASE_URI=postgres://user:password@host:5432/igreja_no_rio

# Payload secret (generate: openssl rand -hex 32)
PAYLOAD_SECRET=your-very-long-random-secret-here

# S3 / Cloudflare R2 storage
S3_BUCKET=igreja-no-rio-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# If using Cloudflare R2 (optional — leave empty for AWS S3):
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Public URL (used for SEO, Open Graph, sitemap)
NEXT_PUBLIC_SERVER_URL=https://igrejanorio.com

# Seed script — first admin user
SEED_ADMIN_EMAIL=admin@igrejanorio.com
SEED_ADMIN_PASSWORD=change-this-password
SEED_ADMIN_NAME=Administrador
