# ─────────────────────────────────────────────────────────────────────────────
# .env.example — desenvolvimento local (Docker Compose)
#
# Copie para .env e suba o stack:
#   cp .env.example .env
#   docker compose up -d
#
# NUNCA commite .env no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (service "db" do docker-compose.yml) ───────────────────────
DATABASE_URI=postgres://postgres:postgres@localhost:5432/igreja_no_rio

# ── Payload CMS ────────────────────────────────────────────────────────────
PAYLOAD_SECRET=dev-secret-local

# ── MinIO — S3 local (service "minio" do docker-compose.yml) ──────────────
S3_BUCKET=igreja-no-rio
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_ENDPOINT=http://localhost:9000

# ── URL pública ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Seed — primeiro usuário admin ─────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@igrejanorio.com
SEED_ADMIN_PASSWORD=senha123
SEED_ADMIN_NAME=Administrador
