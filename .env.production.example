# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — variáveis de produção para Docker Compose
#
# Copie para .env.production e preencha TODOS os valores antes do deploy.
# NUNCA commite .env.production no git.
#
# Uso:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Domínio ────────────────────────────────────────────────────────────────
DOMAIN=igrejanorio.com
NEXT_PUBLIC_SERVER_URL=https://igrejanorio.com

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=igreja_no_rio
POSTGRES_USER=igrejario
# Gere com: openssl rand -hex 16
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ── Payload CMS ────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
PAYLOAD_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_AQUI

# ── MinIO (S3 auto-hospedado) ──────────────────────────────────────────────
# Ou use as credenciais reais da AWS / Cloudflare R2 abaixo.
MINIO_ROOT_USER=igrejario
# Gere com: openssl rand -base64 16  (mínimo 8 chars)
MINIO_ROOT_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

S3_BUCKET=igreja-no-rio
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=${MINIO_ROOT_USER}
S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
# Endpoint interno (MinIO dentro do Docker):
S3_ENDPOINT=http://minio:9000
# Se usar AWS S3 real, remova S3_ENDPOINT e ajuste S3_REGION + credenciais.
# Se usar Cloudflare R2:
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto

# ── Seed (executado apenas uma vez) ────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@igrejanorio.com
SEED_ADMIN_PASSWORD=TROQUE_POR_SENHA_INICIAL
SEED_ADMIN_NAME=Administrador
