# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — produção (Dokploy)
#
# Configure todas as variáveis no Dokploy:
#   Dokploy → serviço → Environment Variables
#
# NUNCA commite valores reais no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Neon / Supabase / Railway ou Postgres próprio
DATABASE_URI=postgresql://user:password@host:5432/igreja_no_rio

# ── Payload CMS ────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
PAYLOAD_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_AQUI

# ── S3 / Cloudflare R2 ─────────────────────────────────────────────────────
S3_BUCKET=igreja-no-rio-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# Cloudflare R2 (remova se usar AWS S3 padrão):
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ── URL pública ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SERVER_URL e usada pelo frontend em build/runtime.
# PAYLOAD_SERVER_URL e a origem canonica usada pelo Payload no runtime.
NEXT_PUBLIC_SERVER_URL=https://igrejanorio.com
PAYLOAD_SERVER_URL=https://igrejanorio.com
PAYLOAD_TRUSTED_ORIGINS=https://igrejanorio.com,https://www.igrejanorio.com
PAYLOAD_CSRF_ORIGINS=https://igrejanorio.com,https://www.igrejanorio.com

# ── Seed — primeiro usuário admin (rodar uma única vez após deploy) ────────
# Defina valores reais antes de rodar o seed inicial.
SEED_ADMIN_EMAIL=admin@igrejanorio.com.br
SEED_ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_E_UNICA
SEED_ADMIN_NAME=Administrador Principal
